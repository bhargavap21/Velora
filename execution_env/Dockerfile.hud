# TODO(Dockerfile.hud): written from template READMEs, not a verified hud v6 base image.
# Confirm the correct base image / `hud serve` entrypoint against a real cloned template
# before relying on this for a hosted run (see env.py's module docstring).

FROM python:3.12-slim

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

CMD ["python", "-m", "execution_env.env"]
